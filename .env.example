# Copy to .env and fill in to use the live model. All values are optional —
# with no .env at all, Samādhān runs fully offline with a deterministic model.

# Live provider API keys. If both are empty, the offline deterministic provider is used.
# If both keys are set and SAMADHAN_PROVIDER is not forced, Anthropic is used.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model ids used when the corresponding provider is selected.
SAMADHAN_MODEL=claude-sonnet-4-6
SAMADHAN_OPENAI_MODEL=gpt-4.1-mini

# Force a provider regardless of the key: "anthropic", "openai", or "mock".
# SAMADHAN_PROVIDER=mock

# HTTP listen address.
SAMADHAN_ADDR=:8080

# Directory the single-page UI is served from.
SAMADHAN_WEB_DIR=web

# Maximum confidential bidding rounds before escalation.
SAMADHAN_MAX_ROUNDS=3

# Seed demo disputes on boot (true/false).
SAMADHAN_SEED=true
